{
  "name": "meta_the_world",
  "version": "1.0.0",
  "description": "Meta The World - AR/VR Metaverse with NFT Land Ownership",
  "main": "index.js",
  "scripts": {
    "bootstrap": "npm install",
    "build": "lerna run build",
    "dev": "lerna run dev --parallel",
    "start": "npm run dev",
    "dev:local": "concurrently \"npm --prefix server run dev\" \"npm --prefix apps/web run dev\"",
    "clean": "lerna clean",
    "test": "lerna run test",
    "web:dev": "lerna run dev --scope=web",
    "mobile:dev": "lerna run start --scope=@meta-the-world/mobile",
    "nft:deploy": "lerna run deploy --scope=nft"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ar",
    "vr",
    "metaverse",
    "nft",
    "blockchain",
    "react",
    "react-native"
  ],
  "author": "YouKnowZo",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "lerna": "^8.1.3",
    "typescript": "^5.4.5"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ]
}
